<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3 class="mb-4"><%= listing.title %></h3>
    <div class="card listing-card mb-4">
      <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing image" >
      <div class="card-body p-4">
        <p class="card-text mb-3"><strong>Description:</strong> <%= listing.description %></p>
        <p class="card-text mb-3"><strong>Price:</strong> &#8377; <%= listing.price.toLocaleString("en-IN") %> / night</p>
        <p class="card-text mb-3"><strong>Location:</strong> <%= listing.location %></p>
        <p class="card-text mb-4"><strong>Country:</strong> <%= listing.country %></p>
        <div class="d-flex gap-2">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">Edit</a>
          <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" style="display:inline;">
            <button class="btn btn-danger">Delete</button>
          </form>
        </div>
      </div>
    </div>
    
    <!-- Add Review Section -->
    <div class="mb-5">
      <hr class="my-4">
      <h4 class="mt-4 mb-4">Add a Review</h4>
      <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
        
        <div class="mb-3">
          <label for="rating" class="form-label"><strong>Rating:</strong></label>
          <div class="d-flex align-items-center gap-3">
            <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range" required style="flex: 1;">
            <span id="ratingValue" style="min-width: 40px; font-weight: bold; color: #ff6b6b;">3</span>
            <span style="min-width: 30px;">/5</span>
          </div>
        </div>
        <div class="mb-4">
          <label for="comments" class="form-label"><strong>Comments:</strong></label>
          <textarea name="review[comment]" id="comments" class="form-control" cols="30" rows="5" required placeholder="Share your experience..."></textarea>
          <div class="invalid-feedback">Please add some comments for the review.</div>
        </div>
        <button class="btn btn-primary mt-2 mb-4">Submit Review</button>
    
      </form>

      <!-- Reviews Display Section -->
      <hr class="my-4">
      <div class="mb-5">
        <h4 class="mt-4 mb-4">Reviews <span class="badge bg-secondary"><%= listing.reviews.length %></span></h4>
        <% if (listing.reviews.length === 0) { %>
          <p class="text-muted">No reviews yet. Be the first to review this listing!</p>
        <% } %>
        <div class="mt-4">
          <% for(let review of listing.reviews) { %>
            <div class="card mb-4">
              <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start">
                  <div class="flex-grow-1">
                    <h6 class="card-subtitle mb-3 text-muted">
                      <% for (let i = 0; i < review.rating; i++) { %>★<% } %><% for (let i = review.rating; i < 5; i++) { %>☆<% } %>
                      <span style="margin-left: 8px; font-weight: bold;"><%= review.rating %>/5</span>
                    </h6>
                    <p class="card-text mb-3"><%= review.comment %></p>
                    <small class="text-muted">
                      <% if (review.createdAt) { %>
                        Reviewed on <%= new Date(review.createdAt).toLocaleDateString() %>
                      <% } %>
                    </small>
                  </div>
                  <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" style="display:inline;">
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                  </form>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</div>
